# ─────────────────────────────────────────────
#  CypherFy — repo-wide .gitignore
# ─────────────────────────────────────────────

# ── Secrets / environment ──
.env
key.properties
*.keystore
*.jks
*.pem
*.p8
*.p12
# Real values for the Flutter release build; see dart_defines.example.json.
dart_defines.json

# ── Dependencies ──
node_modules/

# ── Logs ──
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS / editor ──
.DS_Store
._*
Thumbs.db
*.swp
*.swo
.idea/
*.iml
.vscode/*
.claude/*
!.vscode/extensions.json

# ── Claude Code local ──
.claude/settings.local.json
.claude/._*

# ── Backend (Node) ──
# Uploads (temp multer storage — keep the folder, not its contents)
backend/public/temp/*
!backend/public/temp/.gitkeep

# ── React web (Vite) ──
frontend-web/dist/
frontend-web/dist-ssr/
frontend-web/*.local

# ── Flutter / Dart ──
frontend/build/
frontend/.dart_tool/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/.pub-cache/
frontend/.pub/
frontend/coverage/

# ── Flutter Android ──
frontend/android/.gradle/
frontend/android/build/
frontend/android/local.properties
frontend/android/key.properties
frontend/android/app/debug/
frontend/android/app/profile/
frontend/android/app/release/
frontend/android/.kotlin/

# ── Flutter iOS ──
frontend/ios/Flutter/ephemeral/
frontend/ios/Flutter/App.framework/
frontend/ios/Flutter/Flutter.framework/
frontend/ios/Flutter/Generated.xcconfig
frontend/ios/Flutter/flutter_export_environment.sh
frontend/ios/Pods/
frontend/ios/.symlinks/
**/xcuserdata/
**/DerivedData/

# ── Internal docs / build prompts (not for the public repo) ──
web-frontend-docs/
SECRETCHAT.md
CYPHERFY_RENAME.md
