# React web config — injected at build time via Vite (import.meta.env).

# Backend REST + Socket.io
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_SOCKET_URL=http://localhost:8000

# Google OAuth web client id (must match the backend's verification audience).
VITE_GOOGLE_WEB_CLIENT_ID=

# Firebase web config — required for Google sign-in (copy from the Firebase
# console → Project settings → your Web app). Leave blank to hide the
# "Continue with Google" button gracefully. These are public client identifiers.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_STORAGE_BUCKET=
# Web push (FCM) — also fill in public/firebase-messaging-sw.js with the same config.
VITE_FIREBASE_VAPID_KEY=

# Public URL of the Android APK (R2). When set, shows a "Download for Android" link.
VITE_APK_URL=
