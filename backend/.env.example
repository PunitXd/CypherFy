# App
NODE_ENV=production
PORT=8000

# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/cypherfy

# Redis
REDIS_URL=redis://localhost:6379

# JWT
ACCESS_TOKEN_SECRET=your-access-token-secret-min-32-chars
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_SECRET=your-refresh-token-secret-min-32-chars
REFRESH_TOKEN_EXPIRY=7d

# Cloudflare R2
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET=cypherfy-files
R2_PUBLIC_URL=https://your-custom-domain.com

# Firebase FCM
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Email (nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=CypherFy <noreply@cypherfy.in>

# WebRTC TURN
TURN_SERVER_URL=turn:your-turn-server.com:3478
TURN_USERNAME=cypherfy
TURN_CREDENTIAL=your-turn-password

# Client
CLIENT_URL=http://localhost:3000

GOOGLE_CLIENT_ID=
# Reverse proxy — set when the API runs behind nginx / Render / Railway so
# req.ip and X-Forwarded-For resolve to the real client (required for correct
# IP-based rate limiting). Value is a hop count: "1" = one proxy. Leave unset
# for direct/local runs. Do NOT set to "true" in production (spoofable).
TRUST_PROXY=1

# Rate limiting — all thresholds optional; sensible production defaults apply.
# Master switch (set false to disable all HTTP rate limiting, e.g. in tests):
# RATE_LIMIT_ENABLED=true
#
# Strict auth tier (login/register/reset/OTP/refresh): per-IP + per-account with
# exponential backoff (BASE, BASE*2, BASE*4 … up to MAX) once the free-attempt
# budget in the decay window is spent. Not a hard lockout.
# RATE_LIMIT_AUTH_IP_FREE=30            # free attempts per IP before backoff
# RATE_LIMIT_AUTH_ACCOUNT_FREE=8        # free attempts per email before backoff
# RATE_LIMIT_AUTH_BACKOFF_BASE_MS=30000 # first penalty (30s)
# RATE_LIMIT_AUTH_BACKOFF_MAX_MS=3600000# penalty cap (1h)
# RATE_LIMIT_AUTH_DECAY_MS=3600000      # counters reset after this idle time (1h)
#
# Moderate public tier (guest room create/validate, presigned upload URLs):
# RATE_LIMIT_PUBLIC_WINDOW_MS=60000
# RATE_LIMIT_PUBLIC_MAX=30
#
# Loose authenticated tier (users/requests/calls/permanent rooms), per user id:
# RATE_LIMIT_USER_WINDOW_MS=60000
# RATE_LIMIT_USER_MAX=120
#
# Global safety net across all of /api:
# RATE_LIMIT_GLOBAL_WINDOW_MS=60000
# RATE_LIMIT_GLOBAL_MAX=300
